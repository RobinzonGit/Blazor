@page "/students/details"
@using Microsoft.EntityFrameworkCore
@using BlazorAcademyHW.Models
@inject IDbContextFactory<BlazorAcademyHW.Data.BlazorAcademyHWContext> DbFactory
@inject NavigationManager NavigationManager
@rendermode InteractiveServer

<PageTitle>Details</PageTitle>

<h1>Details</h1>
<h2>Students</h2>
<hr />

@if (students is null)
{
    <p><em>Loading...</em></p>
}
else
{
    <div class="row">
        <!-- Левая колонка: детали -->
        <div class="col-md-8">
            <dl class="row">
                <dt class="col-sm-4">LastName</dt>
                <dd class="col-sm-8">@students.LastName</dd>

                <dt class="col-sm-4">FirstName</dt>
                <dd class="col-sm-8">@students.FirstName</dd>

                <dt class="col-sm-4">MiddleName</dt>
                <dd class="col-sm-8">@students.MiddleName</dd>

                <dt class="col-sm-4">DateOfBirth</dt>
                <dd class="col-sm-8">@students.DateOfBirth.ToShortDateString()</dd>

                <dt class="col-sm-4">Email</dt>
                <dd class="col-sm-8">@students.Email</dd>

                <dt class="col-sm-4">Phone</dt>
                <dd class="col-sm-8">@students.Phone</dd>

                <dt class="col-sm-4">Group</dt>
                <dd class="col-sm-8">@(students.Group?.Name ?? "—")</dd>

                <dt class="col-sm-4">Direction</dt>
                <dd class="col-sm-8">@(students.Group?.Direction?.Name ?? "—")</dd>
            </dl>
            <div class="mt-3 d-flex justify-content-center gap-2">
                <a href="@($"/students/edit?id={students.Id}")" class="btn btn-primary">Edit</a>
                <a href="/students" class="btn btn-secondary">Back to List</a>
            </div>
        </div>

        <!-- Правая колонка: фото и кнопки -->
        <div class="col-md-4 text-center">
            @if (students.Photo != null)
            {
                <img src="data:image/jpeg;base64,@Convert.ToBase64String(students.Photo)"
                     style="max-width: 100%; max-height: 300px; border-radius: 8px;" />
            }
            else
            {
                <div class="border rounded p-5 bg-light d-inline-block">
                    <p class="text-muted">No photo</p>
                </div>
            }
        </div>
    </div>
}

@code {
    private Students? students;

    [SupplyParameterFromQuery]
    private int Id { get; set; }

    protected override async Task OnInitializedAsync()
    {
        using var context = DbFactory.CreateDbContext();
        students = await context.Students
            .Include(s => s.Group)
                .ThenInclude(g => g!.Direction)
            .FirstOrDefaultAsync(m => m.Id == Id);

        if (students is null)
        {
            NavigationManager.NavigateTo("notfound");
        }
    }
}