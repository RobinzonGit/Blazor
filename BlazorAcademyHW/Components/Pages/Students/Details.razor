@page "/students/details"
@using Microsoft.EntityFrameworkCore
@using BlazorAcademyHW.Models
@inject IDbContextFactory<BlazorAcademyHW.Data.BlazorAcademyHWContext> DbFactory
@inject NavigationManager NavigationManager
@rendermode InteractiveServer

<PageTitle>Details</PageTitle>

<h1>Details</h1>

<div>
    <h2>Students</h2>
    <hr />
    @if (students is null)
    {
        <p><em>Loading...</em></p>
    }
    else
    {
        <dl class="row">
            <dt class="col-sm-2">LastName</dt>
            <dd class="col-sm-10">@students.LastName</dd>
            <dt class="col-sm-2">FirstName</dt>
            <dd class="col-sm-10">@students.FirstName</dd>
            <dt class="col-sm-2">MiddleName</dt>
            <dd class="col-sm-10">@students.MiddleName</dd>
            <dt class="col-sm-2">DateOfBirth</dt>
            <dd class="col-sm-10">@students.DateOfBirth</dd>
            <dt class="col-sm-2">Email</dt>
            <dd class="col-sm-10">@students.Email</dd>
            <dt class="col-sm-2">Phone</dt>
            <dd class="col-sm-10">@students.Phone</dd>
            <dt class="col-sm-2">Photo</dt>
            <dd class="col-sm-10">
                @if (students.Photo != null)
                {
                    <img src="data:image/jpeg;base64,@Convert.ToBase64String(students.Photo)" style="max-width:150px;max-height:150px;" />
                }
                else
                {
                    <p>No photo</p>
                }
            </dd>
            <dt class="col-sm-2">Group</dt>
            <dd class="col-sm-10">@(students.Group?.Name ?? "—")</dd>
            <dt class="col-sm-2">Direction</dt>
            <dd class="col-sm-10">@(students.Group?.Direction?.Name ?? "—")</dd>
        </dl>
        <div>
            <a href="@($"/students/edit?id={students.Id}")">Edit</a> |
            <a href="@($"/students")">Back to List</a>
        </div>
    }
</div>

@code {
    private Students? students;

    [SupplyParameterFromQuery]
    private int Id { get; set; }

    protected override async Task OnInitializedAsync()
    {
        using var context = DbFactory.CreateDbContext();
        students = await context.Students
            .Include(s => s.Group)
                .ThenInclude(g => g!.Direction)
            .FirstOrDefaultAsync(m => m.Id == Id);

        if (students is null)
        {
            NavigationManager.NavigateTo("notfound");
        }
    }
}