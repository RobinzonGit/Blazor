@page "/students"
@using Microsoft.EntityFrameworkCore
@using System.Linq
@using Microsoft.AspNetCore.Components.QuickGrid
@using BlazorAcademyHW.Models
@using BlazorAcademyHW.Data
@implements IAsyncDisposable
@inject IDbContextFactory<BlazorAcademyHW.Data.BlazorAcademyHWContext> DbFactory

<PageTitle>Index</PageTitle>
<h1>Index</h1>
<p><a href="students/create">Create New</a></p>

<div class="mb-3 d-flex gap-2 align-items-center">
    <label class="form-label mb-0">Filter by direction:</label>
    <select value="@selectedDirectionId" @onchange="OnDirectionChanged" class="form-select" style="width:220px;">
        <option value="0">-- All Directions --</option>
        @foreach (var d in directions)
        {
            <option value="@d.Id">@d.Name</option>
        }
    </select>

    <label class="form-label mb-0">Filter by group:</label>
    <select value="@selectedGroupId" @onchange="OnGroupChanged" class="form-select" style="width:220px;">
        <option value="0">-- All Groups --</option>
        @foreach (var g in filteredGroups)
        {
            <option value="@g.Id">@g.Name (@g.Direction?.Name)</option>
        }
    </select>

    <button class="btn btn-secondary" @onclick="ApplyFilter">Apply</button>
</div>

<QuickGrid Class="table" Items="studentsList.AsQueryable()">
    <PropertyColumn Property="students => students.LastName" />
    <PropertyColumn Property="students => students.FirstName" />
    <PropertyColumn Property="students => students.MiddleName" />
    <PropertyColumn Property="students => students.DateOfBirth" />
    <PropertyColumn Property="students => students.Email" />
    <PropertyColumn Property="students => students.Phone" />
    <TemplateColumn Title="Direction">
        @if (context.Group?.Direction != null)
        {
            @context.Group.Direction.Name
        }
        else
        {
            <span class="text-muted">—</span>
        }
    </TemplateColumn>
    <TemplateColumn Title="Photo">
        @if (context.Photo != null)
        {
            <img src="data:image/jpeg;base64,@Convert.ToBase64String(context.Photo)" style="max-width:50px;max-height:50px;" />
        }
    </TemplateColumn>
    <TemplateColumn Title="Group">
        @context.Group?.Name
    </TemplateColumn>
    <TemplateColumn Context="students">
        <a href="@($"students/edit?id={students.Id}")">Edit</a> |
        <a href="@($"students/details?id={students.Id}")">Details</a> |
        <a href="@($"students/delete?id={students.Id}")">Delete</a>
    </TemplateColumn>
</QuickGrid>

@code {
    private BlazorAcademyHWContext context = default!;
    private List<Students> studentsList = new();
    private List<Groups> allGroups = new();
    private List<Groups> filteredGroups = new();
    private List<Directions> directions = new();
    private int selectedDirectionId = 0;
    private int selectedGroupId = 0;

    protected override async Task OnInitializedAsync()
    {
        context = DbFactory.CreateDbContext();
        directions = await context.Directions.ToListAsync();
        allGroups = await context.Groups.Include(g => g.Direction).ToListAsync();
        filteredGroups = allGroups;
        await LoadStudents();
    }

    private async Task LoadStudents()
    {
        studentsList = await context.Students
            .Include(s => s.Group)
                .ThenInclude(g => g!.Direction)
            .ToListAsync();
        StateHasChanged();
    }

    private async Task OnDirectionChanged(ChangeEventArgs e)
    {
        selectedDirectionId = int.Parse(e.Value?.ToString() ?? "0");
        filteredGroups = selectedDirectionId == 0
            ? allGroups
            : allGroups.Where(g => g.DirectionId == selectedDirectionId).ToList();
        selectedGroupId = 0;
        await ApplyFilter();
    }

    private async Task OnGroupChanged(ChangeEventArgs e)
    {
        selectedGroupId = int.Parse(e.Value?.ToString() ?? "0");
        await ApplyFilter();
    }

    private async Task ApplyFilter()
    {
        var q = context.Students.Include(s => s.Group).ThenInclude(g => g!.Direction).AsQueryable();
        if (selectedDirectionId != 0)
            q = q.Where(s => s.Group != null && s.Group.DirectionId == selectedDirectionId);
        if (selectedGroupId != 0)
            q = q.Where(s => s.GroupId == selectedGroupId);
        studentsList = await q.ToListAsync();
        StateHasChanged();
    }

    public async ValueTask DisposeAsync() => await context.DisposeAsync();
}