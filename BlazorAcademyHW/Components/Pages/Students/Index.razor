@page "/students"
@using Microsoft.EntityFrameworkCore
@using System.Linq
@using Microsoft.AspNetCore.Components.QuickGrid
@using BlazorAcademyHW.Models
@using BlazorAcademyHW.Data
@inject IDbContextFactory<BlazorAcademyHW.Data.BlazorAcademyHWContext> DbFactory
@rendermode InteractiveServer

<PageTitle>Index</PageTitle>
<h1>Студенты</h1>
<p><a href="students/create">Создать новый</a></p>

<div class="mb-3 d-flex flex-wrap gap-2 align-items-center">
    <label class="form-label mb-0">Фильтр по направлению:</label>
    <select value="@selectedDirectionId" @onchange="OnDirectionChanged" class="form-select" style="width:220px;">
        <option value="0">-- Все направления --</option>
        @foreach (var d in directions)
        {
            <option value="@d.Id">@d.Name</option>
        }
    </select>

    <label class="form-label mb-0">Фильтр по группе:</label>
    <select value="@selectedGroupId" @onchange="OnGroupChanged" class="form-select" style="width:220px;">
        <option value="0">-- Все группы --</option>
        @foreach (var g in filteredGroups)
        {
            <option value="@g.Id">@g.Name</option>
        }
    </select>   
</div>

<div class="mb-3 d-flex flex-wrap gap-2 align-items-center">
    <label class="form-label mb-0">Фамилия:</label>
    <input type="text" value="@lastNameFilter" @oninput="OnLastNameInput" class="form-control" style="width:180px;" placeholder="-Введите Фамилию-" />

    <label class="form-label mb-0">Имя:</label>
    <input type="text" value="@firstNameFilter" @oninput="OnFirstNameInput" class="form-control" style="width:180px;" placeholder="-Введите Имя-" />

    <label class="form-label mb-0">Отчество:</label>
    <input type="text" value="@middleNameFilter" @oninput="OnMiddleNameInput" class="form-control" style="width:180px;" placeholder="-Введите Отчество-" />
</div>

<div class="student-grid" style="overflow-x: auto;">
    <QuickGrid Class="table table-striped" Items="studentsList.AsQueryable()" Pagination="pagination">
        <PropertyColumn Property="students => students.LastName" Sortable="true" Title="Фамилия" />
        <PropertyColumn Property="students => students.FirstName" Sortable="true" Title="Имя" />
        <PropertyColumn Property="students => students.MiddleName" Sortable="true" Title="Отчество" />
        <PropertyColumn Property="students => students.Age" Sortable="true" Title="Возраст" />
        <PropertyColumn Property="students => students.Email" Sortable="true" Title="Email" />
        <PropertyColumn Property="students => students.Phone" Sortable="true" Title="Телефон" />
        <PropertyColumn Property="students => students.DirectionName" Sortable="true" Title="Направление" />
        <TemplateColumn Title="Фото">
            @if (context.Photo != null)
            {
                <img src="data:image/jpeg;base64,@Convert.ToBase64String(context.Photo)" style="max-width:50px;max-height:50px;" />
            }
            else
            {
                <span>Нет фото</span>
            }
        </TemplateColumn>
        <PropertyColumn Property="students => students.GroupName" Sortable="true" Title="Группа" />
        <Paginator State="pagination" />
        <TemplateColumn Context="students">
            <a href="@($"students/edit?id={students.Id}")">Изменить</a> |
            <a href="@($"students/details?id={students.Id}")">Подробно</a> |
            <a href="@($"students/delete?id={students.Id}")">Удалить</a>
        </TemplateColumn>
    </QuickGrid>
</div>


<style>
    .student-grid table {
        table-layout: fixed;
        width: 100%;
    }
    .student-grid th:nth-child(1), .student-grid td:nth-child(1) { width: 10%; }  /* LastName */
    .student-grid th:nth-child(2), .student-grid td:nth-child(2) { width: 10%; }  /* FirstName */
    .student-grid th:nth-child(3), .student-grid td:nth-child(3) { width: 12%; }  /* MiddleName */
    .student-grid th:nth-child(4), .student-grid td:nth-child(4) { width:  8%; }  /* Age */
    .student-grid th:nth-child(5), .student-grid td:nth-child(5) { width: 13%; }  /* Email */
    .student-grid th:nth-child(6), .student-grid td:nth-child(6) { width: 10%; }  /* Phone */
    .student-grid th:nth-child(7), .student-grid td:nth-child(7) { width: 10%; }  /* Direction */
    .student-grid th:nth-child(8), .student-grid td:nth-child(8) { width:  7%; }  /* Photo */
    .student-grid th:nth-child(9), .student-grid td:nth-child(9) { width:  8%; }  /* Group */
    .student-grid th:nth-child(10), .student-grid td:nth-child(10) { width: 12%; } /* Actions */

    .student-grid td {
        word-wrap: break-word;
        overflow-wrap: break-word;
        white-space: normal;
    }
</style>

@code {
    private List<Students> studentsList = new();
    private List<Groups> allGroups = new();
    private List<Groups> filteredGroups = new();
    private List<Directions> directions = new();
    private int selectedDirectionId = 0;
    private int selectedGroupId = 0;
    private PaginationState pagination = new() { ItemsPerPage = 8 };

    // Новые строковые поля для фильтрации
    private string lastNameFilter = "";
    private string firstNameFilter = "";
    private string middleNameFilter = "";

    protected override async Task OnInitializedAsync()
    {
        await LoadFilters();
        await ApplyFilter();
    }

    private async Task LoadFilters()
    {
        using var ctx = DbFactory.CreateDbContext();
        directions = await ctx.Directions.AsNoTracking().ToListAsync();
        allGroups = await ctx.Groups.Include(g => g.Direction).AsNoTracking().ToListAsync();
        filteredGroups = allGroups;
    }

    private async Task ApplyFilter()
    {
        using var ctx = DbFactory.CreateDbContext();
        var query = ctx.Students
            .Include(s => s.Group)
                .ThenInclude(g => g!.Direction)
            .AsNoTracking()
            .AsQueryable();

        // Фильтрация по направлению
        if (selectedDirectionId != 0)
            query = query.Where(s => s.Group != null && s.Group.DirectionId == selectedDirectionId);

        // Фильтрация по группе
        if (selectedGroupId != 0)
            query = query.Where(s => s.GroupId == selectedGroupId);

        // Фильтрация по тексту (нечувствительная к регистру, частичное совпадение)
        if (!string.IsNullOrWhiteSpace(lastNameFilter))
            query = query.Where(s => s.LastName.ToLower().Contains(lastNameFilter.ToLower()));
        if (!string.IsNullOrWhiteSpace(firstNameFilter))
            query = query.Where(s => s.FirstName.ToLower().Contains(firstNameFilter.ToLower()));
        if (!string.IsNullOrWhiteSpace(middleNameFilter))
            query = query.Where(s => s.MiddleName != null && s.MiddleName.ToLower().Contains(middleNameFilter.ToLower()));

        studentsList = await query.ToListAsync();
        await pagination.SetCurrentPageIndexAsync(0);
    }

    // Методы, которые вызываются при изменении текстовых полей и селектов
    private async Task OnDirectionChanged(ChangeEventArgs e)
    {
        selectedDirectionId = int.Parse(e.Value?.ToString() ?? "0");
        filteredGroups = selectedDirectionId == 0
            ? allGroups
            : allGroups.Where(g => g.DirectionId == selectedDirectionId).ToList();
        selectedGroupId = 0;
        await ApplyFilter();
    }

    private async Task OnGroupChanged(ChangeEventArgs e)
    {
        selectedGroupId = int.Parse(e.Value?.ToString() ?? "0");
        await ApplyFilter();
    }
    private async Task OnLastNameInput(ChangeEventArgs e)
{
    lastNameFilter = e.Value?.ToString() ?? "";
    await ApplyFilter();
}

private async Task OnFirstNameInput(ChangeEventArgs e)
{
    firstNameFilter = e.Value?.ToString() ?? "";
    await ApplyFilter();
}

private async Task OnMiddleNameInput(ChangeEventArgs e)
{
    middleNameFilter = e.Value?.ToString() ?? "";
    await ApplyFilter();
}

    // Привязка oninput автоматически вызывает ApplyFilter при каждом изменении текста
    // Так как мы используем @bind:event="oninput", методы set вызываются при каждом вводе символа,
    // и мы можем перехватить это в сеттерах, но проще подписаться на событие в разметке.
    // Вместо этого используем отдельный метод, который будет вызываться по @oninput.
    // Перепишем разметку: вместо @bind:event="oninput" используем @oninput.
    // Легче обновить код, заменив текстовые поля на @oninput с ручным обновлением переменных.
}