@page "/students"
@using Microsoft.EntityFrameworkCore
@using System.Linq
@using Microsoft.AspNetCore.Components.QuickGrid
@using BlazorAcademyHW.Models
@using BlazorAcademyHW.Data
@inject IDbContextFactory<BlazorAcademyHW.Data.BlazorAcademyHWContext> DbFactory
@rendermode InteractiveServer

<PageTitle>Index</PageTitle>
<h1>Students</h1>
<p><a href="students/create">Create New</a></p>

<div class="mb-3 d-flex gap-2 align-items-center">
    <label class="form-label mb-0">Filter by direction:</label>
    <select value="@selectedDirectionId" @onchange="OnDirectionChanged" class="form-select" style="width:220px;">
        <option value="0">-- All Directions --</option>
        @foreach (var d in directions)
        {
            <option value="@d.Id">@d.Name</option>
        }
    </select>

    <label class="form-label mb-0">Filter by group:</label>
    <select value="@selectedGroupId" @onchange="OnGroupChanged" class="form-select" style="width:220px;">
        <option value="0">-- All Groups --</option>
        @foreach (var g in filteredGroups)
        {
            <option value="@g.Id">@g.Name</option>
        }
    </select>

    <button class="btn btn-secondary" @onclick="ApplyFilter">Apply</button>
</div>

<div class="student-grid" style="overflow-x: auto;">
    <QuickGrid Class="table table-striped" Items="studentsList.AsQueryable()" Pagination="pagination">
        <PropertyColumn Property="students => students.LastName" Sortable="true" Title="LastName" />
        <PropertyColumn Property="students => students.FirstName" Sortable="true" Title="FirstName" />
        <PropertyColumn Property="students => students.MiddleName" Sortable="true" Title="MiddleName" />
        <PropertyColumn Property="students => students.Age" Sortable="true" Title="Age" />
        <PropertyColumn Property="students => students.Email" Sortable="true" Title="Email" />
        <PropertyColumn Property="students => students.Phone" Sortable="true" Title="Phone" />
        <PropertyColumn Property="students => students.DirectionName" Sortable="true" Title="Direction" />
        <TemplateColumn Title="Photo">
            @if (context.Photo != null)
            {
                <img src="data:image/jpeg;base64,@Convert.ToBase64String(context.Photo)" style="max-width:50px;max-height:50px;" />
            }
            else
            {
                <span>Нет фото</span>
            }
        </TemplateColumn>
        <PropertyColumn Property="students => students.GroupName" Sortable="true" Title="Group" />
        <Paginator State="pagination" />
        <TemplateColumn Context="students">
            <a href="@($"students/edit?id={students.Id}")">Edit</a> |
            <a href="@($"students/details?id={students.Id}")">Details</a> |
            <a href="@($"students/delete?id={students.Id}")">Delete</a>
        </TemplateColumn>
    </QuickGrid>
</div>


<style>
    .student-grid table {
        table-layout: fixed;
        width: 100%;
    }
    .student-grid th:nth-child(1), .student-grid td:nth-child(1) { width: 10%; }  /* LastName */
    .student-grid th:nth-child(2), .student-grid td:nth-child(2) { width: 10%; }  /* FirstName */
    .student-grid th:nth-child(3), .student-grid td:nth-child(3) { width: 12%; }  /* MiddleName */
    .student-grid th:nth-child(4), .student-grid td:nth-child(4) { width:  8%; }  /* Age */
    .student-grid th:nth-child(5), .student-grid td:nth-child(5) { width: 13%; }  /* Email */
    .student-grid th:nth-child(6), .student-grid td:nth-child(6) { width: 10%; }  /* Phone */
    .student-grid th:nth-child(7), .student-grid td:nth-child(7) { width: 10%; }  /* Direction */
    .student-grid th:nth-child(8), .student-grid td:nth-child(8) { width:  7%; }  /* Photo */
    .student-grid th:nth-child(9), .student-grid td:nth-child(9) { width:  8%; }  /* Group */
    .student-grid th:nth-child(10), .student-grid td:nth-child(10) { width: 12%; } /* Actions */

    /* Исправление наложения текста */
    .student-grid td {
        word-wrap: break-word;
        overflow-wrap: break-word;
        white-space: normal;
    }
</style>

@code {
    private List<Students> studentsList = new();
    private List<Groups> allGroups = new();
    private List<Groups> filteredGroups = new();
    private List<Directions> directions = new();
    private int selectedDirectionId = 0;
    private int selectedGroupId = 0;
    private PaginationState pagination = new() { ItemsPerPage = 8 };

    protected override async Task OnInitializedAsync()
    {
        await LoadFilters();
        await ApplyFilter();
    }

    private async Task LoadFilters()
    {
        using var ctx = DbFactory.CreateDbContext();
        directions = await ctx.Directions.AsNoTracking().ToListAsync();
        allGroups = await ctx.Groups.Include(g => g.Direction).AsNoTracking().ToListAsync();
        filteredGroups = allGroups;
    }

    private async Task ApplyFilter()
    {
        using var ctx = DbFactory.CreateDbContext();
        var query = ctx.Students
            .Include(s => s.Group)
                .ThenInclude(g => g!.Direction)
            .AsNoTracking()
            .AsQueryable();

        if (selectedDirectionId != 0)
            query = query.Where(s => s.Group != null && s.Group.DirectionId == selectedDirectionId);

        if (selectedGroupId != 0)
            query = query.Where(s => s.GroupId == selectedGroupId);

        studentsList = await query.ToListAsync();
        await pagination.SetCurrentPageIndexAsync(0);
    }

    private async Task OnDirectionChanged(ChangeEventArgs e)
    {
        selectedDirectionId = int.Parse(e.Value?.ToString() ?? "0");
        filteredGroups = selectedDirectionId == 0
            ? allGroups
            : allGroups.Where(g => g.DirectionId == selectedDirectionId).ToList();
        selectedGroupId = 0;
        await ApplyFilter();
    }

    private async Task OnGroupChanged(ChangeEventArgs e)
    {
        selectedGroupId = int.Parse(e.Value?.ToString() ?? "0");
        await ApplyFilter();
    }
}