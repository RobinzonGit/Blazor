@page "/students/edit"
@using Microsoft.EntityFrameworkCore
@using BlazorAcademyHW.Models
@inject IDbContextFactory<BlazorAcademyHW.Data.BlazorAcademyHWContext> DbFactory
@inject NavigationManager NavigationManager
@rendermode InteractiveServer

<PageTitle>Edit</PageTitle>
<h1>Edit</h1>
<h2>Студенты</h2>
<hr />
@if (Students is null)
{
    <p><em>Loading...</em></p>
}
else
{
    <EditForm Model="Students" OnValidSubmit="UpdateStudents" FormName="editStudent">
        <DataAnnotationsValidator />
        <ValidationSummary />

        <div class="row">
            <!-- Левая колонка: поля ввода -->
            <div class="col-md-8">
                <input type="hidden" name="Students.Id" value="@Students.Id" />
                <div class="mb-3">
                    <span class="text-danger">*</span>
                    <label for="lastname" class="form-label">Фамилия:</label>
                    <InputText id="lastname" @bind-Value="Students.LastName" class="form-control" />
                </div>
                <div class="mb-3">
                    <span class="text-danger">*</span>
                    <label for="firstname" class="form-label">Имя:</label>
                    <InputText id="firstname" @bind-Value="Students.FirstName" class="form-control" />
                </div>
                <div class="mb-3">
                    <label for="middlename" class="form-label">Отчество:</label>
                    <InputText id="middlename" @bind-Value="Students.MiddleName" class="form-control" />
                </div>
                <div class="mb-3">
                    <label for="dateofbirth" class="form-label">Дата рождения:</label>
                    <InputDate id="dateofbirth" @bind-Value="Students.DateOfBirth" class="form-control" />
                </div>
                <div class="mb-3">
                    <label for="email" class="form-label">Email:</label>
                    <InputText id="email" @bind-Value="Students.Email" class="form-control" />
                </div>
                <div class="mb-3">
                    <label for="phone" class="form-label">Телефон:</label>
                    <InputText id="phone" @bind-Value="Students.Phone" class="form-control" />
                </div>
                <div class="mb-3">
                    <label class="form-label">Группа</label>
                    <select @bind="Students.GroupId" class="form-select">
                        <option value="">-Выберите группу-</option>
                        @foreach (var grp in groups)
                        {
                            <option value="@grp.Id">@grp.Name (@grp.Direction?.Name)</option>
                        }
                    </select>
                </div>
            </div>

            <!-- Правая колонка: фото и управление -->
            <div class="col-md-4 text-center">
                <div class="mb-3">
                    <label class="form-label">Текущее фото</label>
                    @if (Students.Photo != null)
                    {
                        <img src="data:image/jpeg;base64,@Convert.ToBase64String(Students.Photo)"
                             style="max-width:100%; max-height:250px; border-radius:8px;" />
                        <button type="button" class="btn btn-danger btn-sm mt-2" @onclick="DeletePhoto">Удалить</button>
                    }
                    else
                    {
                        <div class="border rounded p-5 bg-light d-inline-block">
                            <p class="text-muted">Нет Фото</p>
                        </div>
                    }
                </div>
                <div class="mb-3">
                    <label class="form-label">Загрузите фото</label>
                    <InputFile OnChange="OnPhotoUpload" />
                </div>
                <button type="submit" class="btn btn-primary mt-3">Сохранить</button>
                <a href="/students" class="btn btn-secondary mt-3">Отменить</a>
            </div>
        </div>
    </EditForm>
}
<div class="mt-3"><a href="/students">Вернутся к списку</a></div>

@code {
    [SupplyParameterFromQuery] private int Id { get; set; }
    private Students? Students { get; set; }
    private List<Groups> groups = new();

    protected override async Task OnInitializedAsync()
    {
        using var context = DbFactory.CreateDbContext();
        groups = await context.Groups.Include(g => g.Direction).ToListAsync();
        Students = await context.Students.FirstOrDefaultAsync(m => m.Id == Id);
        if (Students is null) NavigationManager.NavigateTo("notfound");
    }

    private async Task OnPhotoUpload(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file != null && Students != null)
        {
            using var ms = new MemoryStream();
            await file.OpenReadStream(maxAllowedSize: 5_000_000).CopyToAsync(ms);
            Students.Photo = ms.ToArray();
        }
    }

    private void DeletePhoto()
    {
        if (Students != null)
            Students.Photo = null;
    }

    private async Task UpdateStudents()
    {
        using var context = DbFactory.CreateDbContext();
        var existing = await context.Students.FirstOrDefaultAsync(s => s.Id == Students!.Id);
        if (existing == null)
        {
            NavigationManager.NavigateTo("notfound");
            return;
        }

        existing.LastName = Students.LastName;
        existing.FirstName = Students.FirstName;
        existing.MiddleName = Students.MiddleName;
        existing.DateOfBirth = Students.DateOfBirth;
        existing.Email = Students.Email;
        existing.Phone = Students.Phone;
        existing.Photo = Students.Photo;
        existing.GroupId = Students.GroupId;

        await context.SaveChangesAsync();
        NavigationManager.NavigateTo("/students");
    }
}