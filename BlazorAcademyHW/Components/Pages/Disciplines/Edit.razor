@page "/disciplines/edit"
@using Microsoft.EntityFrameworkCore
@using BlazorAcademyHW.Models
@inject IDbContextFactory<BlazorAcademyHW.Data.BlazorAcademyHWContext> DbFactory
@inject NavigationManager NavigationManager
@rendermode InteractiveServer

<PageTitle>Edit</PageTitle>
<h1>Edit</h1>
<h2>Disciplines</h2>
<hr />
@if (Disciplines is null)
{
    <p><em>Loading...</em></p>
}
else
{
    <div class="row">
        <div class="col-md-4">
            <EditForm Model="Disciplines" OnValidSubmit="UpdateDisciplines" FormName="editDiscipline">
                <DataAnnotationsValidator />
                <ValidationSummary />
                <input type="hidden" name="Disciplines.Id" value="@Disciplines.Id" />
                <div class="mb-3">
                    <span class="text-danger">*</span>
                    <label for="name">Name:</label>
                    <InputText id="name" @bind-Value="Disciplines.Name" class="form-control" />
                </div>
                <div class="mb-3">
                    <label for="lessons">Lessons:</label>
                    <InputNumber id="lessons" @bind-Value="Disciplines.Lessons" class="form-control" />
                </div>
                <div class="mb-3">
                    <label>Teachers</label>
                    <div class="border rounded p-2" style="max-height: 200px; overflow-y: auto;">
                        @foreach (var t in allTeachers)
                        {
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" value="@t.Id"
                                       checked="@selectedTeacherIds.Contains(t.Id)"
                                       @onchange="e => ToggleTeacher(t.Id, (bool)(e.Value ?? false))" />
                                <label class="form-check-label" for="@($"teacher_{t.Id}")">
                                    @t.LastName @t.FirstName
                                </label>
                            </div>
                        }
                    </div>
                </div>
                <button type="submit" class="btn btn-primary">Save</button>
            </EditForm>
        </div>
    </div>
}
<div><a href="/disciplines">Back to List</a></div>

@code {
    [SupplyParameterFromQuery] private int Id { get; set; }
    private List<Teachers> allTeachers = new();
    private List<int> selectedTeacherIds = new();
    private Disciplines? Disciplines { get; set; }

    protected override async Task OnInitializedAsync()
    {
        using var context = DbFactory.CreateDbContext();
        Disciplines = await context.Disciplines.FirstOrDefaultAsync(m => m.Id == Id);
        if (Disciplines is null)
        {
            NavigationManager.NavigateTo("notfound");
            return;
        }
        allTeachers = await context.Teachers.ToListAsync();
        await context.Entry(Disciplines).Collection(d => d.TeacherDisciplines).LoadAsync();
        selectedTeacherIds = Disciplines.TeacherDisciplines.Select(td => td.TeacherId).ToList();
    }

    private void ToggleTeacher(int teacherId, bool isChecked)
    {
        if (isChecked)
        {
            if (!selectedTeacherIds.Contains(teacherId))
                selectedTeacherIds.Add(teacherId);
        }
        else
        {
            selectedTeacherIds.Remove(teacherId);
        }
    }

    private async Task UpdateDisciplines()
    {
        using var context = DbFactory.CreateDbContext();
        var discipline = await context.Disciplines
            .Include(d => d.TeacherDisciplines)
            .FirstOrDefaultAsync(d => d.Id == Disciplines!.Id);
        if (discipline == null) return;

        discipline.Name = Disciplines.Name;
        discipline.Lessons = Disciplines.Lessons;
        discipline.TeacherDisciplines.Clear();
        foreach (var tid in selectedTeacherIds)
            discipline.TeacherDisciplines.Add(new TeacherDiscipline { TeacherId = tid, DisciplineId = discipline.Id });

        await context.SaveChangesAsync();
        NavigationManager.NavigateTo("/disciplines");
    }
}