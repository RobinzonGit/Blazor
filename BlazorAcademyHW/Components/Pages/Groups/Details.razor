@page "/groups/details"
@using Microsoft.EntityFrameworkCore
@using BlazorAcademyHW.Models
@inject IDbContextFactory<BlazorAcademyHW.Data.BlazorAcademyHWContext> DbFactory
@inject NavigationManager NavigationManager
@rendermode InteractiveServer

<PageTitle>Details</PageTitle>

<h1>Details</h1>

<div>
    <h2>Groups</h2>
    <hr />
    @if (groups is null)
    {
        <p><em>Loading...</em></p>
    }
    else {
        <dl class="row">
            <dt class="col-sm-2">Name</dt>
            <dd class="col-sm-10">@groups.Name</dd>
            <dt class="col-sm-2">Direction</dt>
            <dd class="col-sm-10">@groups.Direction?.Name</dd>
            <dt class="col-sm-2">Study Days</dt>
            <dd class="col-sm-10">@DisplayStudyDays(groups.StudyDays)</dd>
        </dl>
        <div>
            <a href="@($"/groups/edit?id={groups.Id}")">Edit</a> |
            <a href="@($"/groups")">Back to List</a>
        </div>
    }
</div>

@code {
    private Groups? groups;

    [SupplyParameterFromQuery]
    private int Id { get; set; }

    protected override async Task OnInitializedAsync()
    {
        using var context = DbFactory.CreateDbContext();
        groups = await context.Groups.Include(g => g.Direction).FirstOrDefaultAsync(m => m.Id == Id);

        if (groups is null)
        {
            NavigationManager.NavigateTo("notfound");
        }
    }

    private static string DisplayStudyDays(string? studyDays)
    {
        if (string.IsNullOrWhiteSpace(studyDays)) return string.Empty;
        var map = new[] { "Пн.", "Вт.", "Ср.", "Чт.", "Пт.", "Сб.", "Вс." };
        var parts = studyDays.Split(',', StringSplitOptions.RemoveEmptyEntries);
        var names = parts.Select(p =>
        {
            if (int.TryParse(p, out var v) && v >= 0 && v < map.Length) return map[v];
            return null;
        }).Where(x => x != null)!;
        return string.Join(',', names);
    }
}
