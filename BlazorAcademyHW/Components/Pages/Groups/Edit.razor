@page "/groups/edit"
@using Microsoft.EntityFrameworkCore
@using BlazorAcademyHW.Models
@inject IDbContextFactory<BlazorAcademyHW.Data.BlazorAcademyHWContext> DbFactory
@inject NavigationManager NavigationManager
@rendermode InteractiveServer

<PageTitle>Edit</PageTitle>
<h1>Edit</h1>

@if (group == null)
{
    <p><em>Loading...</em></p>
}
else
{
    <EditForm Model="group" OnValidSubmit="UpdateGroup" FormName="editGroup">
        <DataAnnotationsValidator />
        <ValidationSummary />

        <div class="mb-3">
            <label class="form-label">Name</label>
            <InputText @bind-Value="group.Name" class="form-control" />
        </div>

        <div class="mb-3">
            <label class="form-label">Direction</label>
            <select @bind="group.DirectionId" class="form-select">
                <option value="0">-- Select Direction --</option>
                @foreach (var dir in directions)
                {
                    <option value="@dir.Id">@dir.Name</option>
                }
            </select>
        </div>

        <div class="mb-3">
            <label class="form-label">Study Days</label>
            <div class="d-flex flex-wrap gap-2">
                @foreach (var day in studyDaysOptions)
                {
                    <div class="form-check">
                        <input type="checkbox" class="form-check-input" @bind="day.Selected" id="day_@day.Value" />
                        <label class="form-check-label" for="day_@day.Value">@day.Name</label>
                    </div>
                }
            </div>
        </div>

        <button type="submit" class="btn btn-primary">Save</button>
        <a href="/groups" class="btn btn-secondary">Cancel</a>
    </EditForm>
}

@code {
    [SupplyParameterFromQuery] private int Id { get; set; }

    private Groups? group;
    private List<Directions> directions = new();

    private class DayOption
    {
        public string Name { get; set; } = "";
        public int Value { get; set; }
        public bool Selected { get; set; }
    }

    private List<DayOption> studyDaysOptions = new()
    {
        new() { Name = "Monday", Value = 0 },
        new() { Name = "Tuesday", Value = 1 },
        new() { Name = "Wednesday", Value = 2 },
        new() { Name = "Thursday", Value = 3 },
        new() { Name = "Friday", Value = 4 },
        new() { Name = "Saturday", Value = 5 },
        new() { Name = "Sunday", Value = 6 }
    };

    protected override async Task OnInitializedAsync()
    {
        using var context = DbFactory.CreateDbContext();
        directions = await context.Directions.ToListAsync();
        group = await context.Groups.FirstOrDefaultAsync(g => g.Id == Id);
        if (group == null)
        {
            NavigationManager.NavigateTo("notfound");
            return;
        }

        if (!string.IsNullOrWhiteSpace(group.StudyDays))
        {
            var selected = group.StudyDays.Split(',', StringSplitOptions.RemoveEmptyEntries)
                           .Select(s => int.TryParse(s, out var v) ? v : -1)
                           .Where(v => v >= 0).ToHashSet();
            foreach (var d in studyDaysOptions)
                d.Selected = selected.Contains(d.Value);
        }
    }

    private async Task UpdateGroup()
    {
        var newStudyDays = string.Join(",", studyDaysOptions.Where(d => d.Selected).Select(d => d.Value));

        using var context = DbFactory.CreateDbContext();
        var existing = await context.Groups.FirstOrDefaultAsync(g => g.Id == group!.Id);
        if (existing == null) return;

        existing.Name = group.Name;
        existing.DirectionId = group.DirectionId;
        existing.StudyDays = newStudyDays;

        await context.SaveChangesAsync();
        NavigationManager.NavigateTo("/groups");
    }
}