@page "/teachers"
@using Microsoft.EntityFrameworkCore
@using System.Linq
@using Microsoft.AspNetCore.Components.QuickGrid
@using BlazorAcademyHW.Models
@using BlazorAcademyHW.Data
@inject IDbContextFactory<BlazorAcademyHW.Data.BlazorAcademyHWContext> DbFactory
@rendermode InteractiveServer

<PageTitle>Index</PageTitle>
<h1>Преподаватели</h1>
<p><a href="teachers/create">Создать новый</a></p>

<div class="mb-3 d-flex flex-wrap gap-2 align-items-center">
    <label class="form-label mb-0">Фамилия:</label>
    <input type="text" value="@lastNameFilter" @oninput="OnLastNameInput" class="form-control" style="width:180px;" placeholder="-Введите Фамилию-" />

    <label class="form-label mb-0">Имя:</label>
    <input type="text" value="@firstNameFilter" @oninput="OnFirstNameInput" class="form-control" style="width:180px;" placeholder="-Введите Имя-" />

    <label class="form-label mb-0">Отчество:</label>
    <input type="text" value="@middleNameFilter" @oninput="OnMiddleNameInput" class="form-control" style="width:180px;" placeholder="-Введите Отчество-" />
</div>

<div class="teacher-grid" style="overflow-x: auto;">
    <QuickGrid Class="table table-striped" Items="teachersList.AsQueryable()" Pagination="pagination">
        <PropertyColumn Property="teachers => teachers.LastName" Sortable="true" Title="Фамилия" />
        <PropertyColumn Property="teachers => teachers.FirstName" Sortable="true" Title="Имя" />
        <PropertyColumn Property="teachers => teachers.MiddleName" Sortable="true" Title="Отчество" />
        <PropertyColumn Property="teachers => teachers.Age" Sortable="true" Title="Возраст" />
        <PropertyColumn Property="teachers => teachers.Email" Sortable="true" Title="Email" />
        <PropertyColumn Property="teachers => teachers.Phone" Sortable="true" Title="Телефон" />
        <TemplateColumn Title="Фото">
            @if (context.PhotoData != null)
            {
                <img src="data:image/jpeg;base64,@Convert.ToBase64String(context.PhotoData)" style="max-width:50px;max-height:50px;" />
            }
            else
            {
                <span>Нет фото</span>
            }
        </TemplateColumn>
        <PropertyColumn Property="teachers => teachers.WorkSince" Sortable="true" Title="Дата начала работы" />
        <PropertyColumn Property="teachers => teachers.Rate" Sortable="true" Title="Ставка" />
        <Paginator State="pagination" />
        <TemplateColumn Context="teachers">
            <a href="@($"teachers/edit?id={teachers.Id}")">Изменить</a> |
            <a href="@($"teachers/details?id={teachers.Id}")">Подробно</a> |
            <a href="@($"teachers/delete?id={teachers.Id}")">Удалить</a>
        </TemplateColumn>
    </QuickGrid>
</div>


<style>
    .teacher-grid table {
        table-layout: fixed;
        width: 100%;
    }
    .teacher-grid th:nth-child(1), .teacher-grid td:nth-child(1) { width: 10%; }  /* LastName */
    .teacher-grid th:nth-child(2), .teacher-grid td:nth-child(2) { width: 10%; }  /* FirstName */
    .teacher-grid th:nth-child(3), .teacher-grid td:nth-child(3) { width: 11%; }  /* MiddleName */
    .teacher-grid th:nth-child(4), .teacher-grid td:nth-child(4) { width:  6%; }  /* Age */
    .teacher-grid th:nth-child(5), .teacher-grid td:nth-child(5) { width: 13%; }  /* Email */
    .teacher-grid th:nth-child(6), .teacher-grid td:nth-child(6) { width:  9%; }  /* Phone */
    .teacher-grid th:nth-child(7), .teacher-grid td:nth-child(7) { width:  6%; }  /* Photo */
    .teacher-grid th:nth-child(8), .teacher-grid td:nth-child(8) { width:  8%; }  /* WorkSince */
    .teacher-grid th:nth-child(9), .teacher-grid td:nth-child(9) { width:  6%; }  /* Rate */
    .teacher-grid th:nth-child(10), .teacher-grid td:nth-child(10) { width: 11%; } /* Actions */

    .teacher-grid td {
        word-wrap: break-word;
        overflow-wrap: break-word;
        white-space: normal;
    }
</style>

@code {
    private List<Teachers> teachersList = new();
    private PaginationState pagination = new() { ItemsPerPage = 6 };

    private string lastNameFilter = "";
    private string firstNameFilter = "";
    private string middleNameFilter = "";

    protected override async Task OnInitializedAsync()
    {
        await LoadTeachers();
    }

    private async Task LoadTeachers()
    {
        using var ctx = DbFactory.CreateDbContext();
        teachersList = await ctx.Teachers
            .AsNoTracking()
            .ToListAsync();

        await pagination.SetCurrentPageIndexAsync(0);
    }

    private async Task ApplyFilter()
    {
        using var ctx = DbFactory.CreateDbContext();
        var query = ctx.Teachers.AsNoTracking().AsQueryable();

        if (!string.IsNullOrWhiteSpace(lastNameFilter))
            query = query.Where(t => t.LastName.ToLower().Contains(lastNameFilter.ToLower()));
        if (!string.IsNullOrWhiteSpace(firstNameFilter))
            query = query.Where(t => t.FirstName.ToLower().Contains(firstNameFilter.ToLower()));
        if (!string.IsNullOrWhiteSpace(middleNameFilter))
            query = query.Where(t => t.MiddleName != null && t.MiddleName.ToLower().Contains(middleNameFilter.ToLower()));

        teachersList = await query.ToListAsync();
        await pagination.SetCurrentPageIndexAsync(0);
    }

    private async Task OnLastNameInput(ChangeEventArgs e)
    {
        lastNameFilter = e.Value?.ToString() ?? "";
        await ApplyFilter();
    }

    private async Task OnFirstNameInput(ChangeEventArgs e)
    {
        firstNameFilter = e.Value?.ToString() ?? "";
        await ApplyFilter();
    }

    private async Task OnMiddleNameInput(ChangeEventArgs e)
    {
        middleNameFilter = e.Value?.ToString() ?? "";
        await ApplyFilter();
    }
}