@page "/teachers/details"
@using Microsoft.EntityFrameworkCore
@using BlazorAcademyHW.Models
@inject IDbContextFactory<BlazorAcademyHW.Data.BlazorAcademyHWContext> DbFactory
@inject NavigationManager NavigationManager
@rendermode InteractiveServer

<PageTitle>Details</PageTitle>

<h1>Details</h1>

<div>
    <h2>Teachers</h2>
    <hr />
    @if (teachers is null)
    {
        <p><em>Loading...</em></p>
    }
    else {
        <dl class="row">
            <dt class="col-sm-2">LastName</dt>
            <dd class="col-sm-10">@teachers.LastName</dd>
            <dt class="col-sm-2">FirstName</dt>
            <dd class="col-sm-10">@teachers.FirstName</dd>
            <dt class="col-sm-2">MiddleName</dt>
            <dd class="col-sm-10">@teachers.MiddleName</dd>
            <dt class="col-sm-2">DateOfBirth</dt>
            <dd class="col-sm-10">@teachers.DateOfBirth</dd>
            <dt class="col-sm-2">Email</dt>
            <dd class="col-sm-10">@teachers.Email</dd>
            <dt class="col-sm-2">Phone</dt>
            <dd class="col-sm-10">@teachers.Phone</dd>
            <dt class="col-sm-2">Photo</dt>
            <dd class="col-sm-10">@teachers.PhotoData</dd>
            <dt class="col-sm-2">WorkSince</dt>
            <dd class="col-sm-10">@teachers.WorkSince</dd>
            <dt class="col-sm-2">Rate</dt>
            <dd class="col-sm-10">@teachers.Rate</dd>
        </dl>
        <div>
            <a href="@($"/teachers/edit?id={teachers.Id}")">Edit</a> |
            <a href="@($"/teachers")">Back to List</a>
        </div>
        <h3>Disciplines this teacher can teach</h3>
        @if (teachers?.TeacherDisciplines != null && teachers.TeacherDisciplines.Any())
        {
            <ul>
                @foreach (var td in teachers.TeacherDisciplines)
                {
                    <li>@td.Discipline.Name</li>
                }
            </ul>
        }
        else
        {
            <p>No disciplines assigned.</p>
        }
        <h3>Also shows discipline lists for each teacher (bidirectional)</h3>
        @* Already showing disciplines for this teacher via TeacherDisciplines. The disciplines page lists teachers for each discipline. *@
    }
</div>

@code {
    private Teachers? teachers;

    [SupplyParameterFromQuery]
    private int Id { get; set; }

    protected override async Task OnInitializedAsync()
    {
        using var context = DbFactory.CreateDbContext();
        teachers = await context.Teachers
        .Include(t => t.TeacherDisciplines)
            .ThenInclude(td => td.Discipline)
        .FirstOrDefaultAsync(m => m.Id == Id);

        if (teachers is null)
        {
            NavigationManager.NavigateTo("notfound");
        }
    }
}
