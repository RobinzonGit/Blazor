@page "/teachers/details"
@using Microsoft.EntityFrameworkCore
@using BlazorAcademyHW.Models
@inject IDbContextFactory<BlazorAcademyHW.Data.BlazorAcademyHWContext> DbFactory
@inject NavigationManager NavigationManager
@rendermode InteractiveServer

<PageTitle>Details</PageTitle>

<h1>Details</h1>
<h2>Teachers</h2>
<hr />

@if (teachers is null)
{
    <p><em>Loading...</em></p>
}
else
{
    <div class="row">
        <!-- Левая колонка: детали и дисциплины -->
        <div class="col-md-8">
            <dl class="row">
                <dt class="col-sm-4">LastName</dt>
                <dd class="col-sm-8">@teachers.LastName</dd>

                <dt class="col-sm-4">FirstName</dt>
                <dd class="col-sm-8">@teachers.FirstName</dd>

                <dt class="col-sm-4">MiddleName</dt>
                <dd class="col-sm-8">@teachers.MiddleName</dd>

                <dt class="col-sm-4">DateOfBirth</dt>
                <dd class="col-sm-8">@teachers.DateOfBirth.ToShortDateString()</dd>

                <dt class="col-sm-4">Email</dt>
                <dd class="col-sm-8">@teachers.Email</dd>

                <dt class="col-sm-4">Phone</dt>
                <dd class="col-sm-8">@teachers.Phone</dd>

                <dt class="col-sm-4">WorkSince</dt>
                <dd class="col-sm-8">@teachers.WorkSince.ToShortDateString()</dd>

                <dt class="col-sm-4">Rate</dt>
                <dd class="col-sm-8">@teachers.Rate</dd>
            </dl>

            <h3>Disciplines this teacher can teach</h3>
            @if (teachers.TeacherDisciplines != null && teachers.TeacherDisciplines.Any())
            {
                <ul>
                    @foreach (var td in teachers.TeacherDisciplines)
                    {
                        <li>@td.Discipline.Name</li>
                    }
                </ul>
            }
            else
            {
                <p>No disciplines assigned.</p>
            }
            <div class="mt-3 d-flex justify-content-center gap-2">
                <a href="@($"/teachers/edit?id={teachers.Id}")" class="btn btn-primary">Edit</a>
                <a href="/teachers" class="btn btn-secondary">Back to List</a>
            </div>
        </div>

        <!-- Правая колонка: фото и кнопки -->
        <div class="col-md-4 text-center">
            @if (teachers.PhotoData != null)
            {
                <img src="data:image/jpeg;base64,@Convert.ToBase64String(teachers.PhotoData)"
                     style="max-width: 100%; max-height: 300px; border-radius: 8px;" />
            }
            else
            {
                <div class="border rounded p-5 bg-light d-inline-block">
                    <p class="text-muted">No photo</p>
                </div>
            }
        </div>
    </div>
}

@code {
    private Teachers? teachers;

    [SupplyParameterFromQuery]
    private int Id { get; set; }

    protected override async Task OnInitializedAsync()
    {
        using var context = DbFactory.CreateDbContext();
        teachers = await context.Teachers
            .Include(t => t.TeacherDisciplines)
                .ThenInclude(td => td.Discipline)
            .FirstOrDefaultAsync(m => m.Id == Id);

        if (teachers is null)
        {
            NavigationManager.NavigateTo("notfound");
        }
    }
}