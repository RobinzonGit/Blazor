@page "/teachers/edit"
@using Microsoft.EntityFrameworkCore
@using BlazorAcademyHW.Models
@inject IDbContextFactory<BlazorAcademyHW.Data.BlazorAcademyHWContext> DbFactory
@inject NavigationManager NavigationManager
@rendermode InteractiveServer

<PageTitle>Edit</PageTitle>
<h1>Edit</h1>
<h2>Teachers</h2>
<hr />
@if (Teachers is null)
{
    <p><em>Loading...</em></p>
}
else
{
    <EditForm Model="Teachers" OnValidSubmit="UpdateTeachers" FormName="editTeacher">
        <DataAnnotationsValidator />
        <ValidationSummary />

        <div class="row">
            <!-- Левая колонка: поля ввода -->
            <div class="col-md-8">
                <input type="hidden" name="Teachers.Id" value="@Teachers.Id" />
                <div class="mb-3">
                    <span class="text-danger">*</span>
                    <label for="lastname">LastName:</label>
                    <InputText id="lastname" @bind-Value="Teachers.LastName" class="form-control" />
                </div>
                <div class="mb-3">
                    <span class="text-danger">*</span>
                    <label for="firstname">FirstName:</label>
                    <InputText id="firstname" @bind-Value="Teachers.FirstName" class="form-control" />
                </div>
                <div class="mb-3">
                    <label for="middlename">MiddleName:</label>
                    <InputText id="middlename" @bind-Value="Teachers.MiddleName" class="form-control" />
                </div>
                <div class="mb-3">
                    <label for="dateofbirth">DateOfBirth:</label>
                    <InputDate id="dateofbirth" @bind-Value="Teachers.DateOfBirth" class="form-control" />
                </div>
                <div class="mb-3">
                    <label for="email">Email:</label>
                    <InputText id="email" @bind-Value="Teachers.Email" class="form-control" />
                </div>
                <div class="mb-3">
                    <label for="phone">Phone:</label>
                    <InputText id="phone" @bind-Value="Teachers.Phone" class="form-control" />
                </div>
                <div class="mb-3">
                    <label for="worksince">WorkSince:</label>
                    <InputDate id="worksince" @bind-Value="Teachers.WorkSince" class="form-control" />
                </div>
                <div class="mb-3">
                    <label for="rate">Rate:</label>
                    <InputNumber id="rate" @bind-Value="Teachers.Rate" class="form-control" />
                </div>
            </div>

            <!-- Правая колонка: фото и управление -->
            <div class="col-md-4 text-center">
                <div class="mb-3">
                    <label class="form-label">Current Photo:</label>
                    @if (Teachers.PhotoData != null)
                    {
                        <img src="data:image/jpeg;base64,@Convert.ToBase64String(Teachers.PhotoData)"
                             style="max-width:100%; max-height:250px; border-radius:8px;" />
                        <button type="button" class="btn btn-danger btn-sm mt-2" @onclick="DeletePhoto">Delete Photo</button>
                    }
                    else
                    {
                        <div class="border rounded p-5 bg-light d-inline-block">
                            <p class="text-muted">No photo</p>
                        </div>
                    }
                </div>
                <div class="mb-3">
                    <label for="photo" class="form-label">Change Photo:</label>
                    <InputFile OnChange="OnPhotoUpload" />
                </div>
                <button type="submit" class="btn btn-primary mt-3">Save</button>
                <a href="/teachers" class="btn btn-secondary mt-3">Cancel</a>
            </div>
        </div>
    </EditForm>
}
<div class="mt-3"><a href="/teachers">Back to List</a></div>

@code {
    [SupplyParameterFromQuery] private int Id { get; set; }
    private Teachers? Teachers { get; set; }

    protected override async Task OnInitializedAsync()
    {
        using var context = DbFactory.CreateDbContext();
        Teachers = await context.Teachers.FirstOrDefaultAsync(m => m.Id == Id);
        if (Teachers is null) NavigationManager.NavigateTo("notfound");
    }

    private async Task OnPhotoUpload(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file != null && Teachers != null)
        {
            using var ms = new MemoryStream();
            await file.OpenReadStream(maxAllowedSize: 5_000_000).CopyToAsync(ms);
            Teachers.PhotoData = ms.ToArray();
        }
    }

    private void DeletePhoto()
    {
        if (Teachers != null)
            Teachers.PhotoData = null;
    }

    private async Task UpdateTeachers()
    {
        using var context = DbFactory.CreateDbContext();
        var existing = await context.Teachers.FirstOrDefaultAsync(t => t.Id == Teachers!.Id);
        if (existing == null)
        {
            NavigationManager.NavigateTo("notfound");
            return;
        }

        existing.LastName = Teachers.LastName;
        existing.FirstName = Teachers.FirstName;
        existing.MiddleName = Teachers.MiddleName;
        existing.DateOfBirth = Teachers.DateOfBirth;
        existing.Email = Teachers.Email;
        existing.Phone = Teachers.Phone;
        existing.PhotoData = Teachers.PhotoData;
        existing.WorkSince = Teachers.WorkSince;
        existing.Rate = Teachers.Rate;

        await context.SaveChangesAsync();
        NavigationManager.NavigateTo("/teachers");
    }
}