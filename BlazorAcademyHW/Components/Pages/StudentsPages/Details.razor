@page "/students/details"
@using Microsoft.EntityFrameworkCore
@using BlazorAcademyHW.Models
@inject IDbContextFactory<BlazorAcademyHW.Data.BlazorAcademyHWContext> DbFactory
@inject NavigationManager NavigationManager

<PageTitle>Details</PageTitle>

<h1>Details</h1>

<div>
    <h2>Students</h2>
    <hr />
    @if (students is null)
    {
        <p><em>Loading...</em></p>
    }
    else {
        <dl class="row">
            <dt class="col-sm-2">last_Name</dt>
            <dd class="col-sm-10">@students.last_Name</dd>
            <dt class="col-sm-2">first_Nam</dt>
            <dd class="col-sm-10">@students.first_Nam</dd>
            <dt class="col-sm-2">middle_name</dt>
            <dd class="col-sm-10">@students.middle_name</dd>
            <dt class="col-sm-2">DateOfBirth</dt>
            <dd class="col-sm-10">@students.DateOfBirth</dd>
            <dt class="col-sm-2">email</dt>
            <dd class="col-sm-10">@students.email</dd>
            <dt class="col-sm-2">phone</dt>
            <dd class="col-sm-10">@students.phone</dd>
            <dt class="col-sm-2">photo</dt>
            <dd class="col-sm-10">@students.photo</dd>
            <dt class="col-sm-2">group</dt>
            <dd class="col-sm-10">@students.group</dd>
        </dl>
        <div>
            <a href="@($"/students/edit?id={students.Id}")">Edit</a> |
            <a href="@($"/students")">Back to List</a>
        </div>
    }
</div>

@code {
    private Students? students;

    [SupplyParameterFromQuery]
    private int Id { get; set; }

    protected override async Task OnInitializedAsync()
    {
        using var context = DbFactory.CreateDbContext();
        students = await context.Students.FirstOrDefaultAsync(m => m.Id == Id);

        if (students is null)
        {
            NavigationManager.NavigateTo("notfound");
        }
    }
}
