@page "/groups/details"
@using Microsoft.EntityFrameworkCore
@using BlazorAcademyHW.Models
@inject IDbContextFactory<BlazorAcademyHW.Data.BlazorAcademyHWContext> DbFactory
@inject NavigationManager NavigationManager

<PageTitle>Details</PageTitle>

<h1>Details</h1>

<div>
    <h2>Groups</h2>
    <hr />
    @if (groups is null)
    {
        <p><em>Loading...</em></p>
    }
    else {
        <dl class="row">
            <dt class="col-sm-2">Name</dt>
            <dd class="col-sm-10">@groups.Name</dd>
            <dt class="col-sm-2">Direction</dt>
            <dd class="col-sm-10">@groups.Direction</dd>
        </dl>
        <div>
            <a href="@($"/groups/edit?id={groups.Id}")">Edit</a> |
            <a href="@($"/groups")">Back to List</a>
        </div>
    }
</div>

@code {
    private Groups? groups;

    [SupplyParameterFromQuery]
    private int Id { get; set; }

    protected override async Task OnInitializedAsync()
    {
        using var context = DbFactory.CreateDbContext();
        groups = await context.Groups.FirstOrDefaultAsync(m => m.Id == Id);

        if (groups is null)
        {
            NavigationManager.NavigateTo("notfound");
        }
    }
}
